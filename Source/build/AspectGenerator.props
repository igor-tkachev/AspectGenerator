<Project>
	<PropertyGroup>
		<AspectGeneratorInterceptorsNamespace Condition="'$(AspectGeneratorInterceptorsNamespace)' == ''">AspectGenerator</AspectGeneratorInterceptorsNamespace>

		<AspectGeneratorGenerateApi Condition="'$(AspectGeneratorGenerateApi)' == ''">true</AspectGeneratorGenerateApi>
		<AspectGeneratorPublicApi Condition="'$(AspectGeneratorPublicApi)' == ''">false</AspectGeneratorPublicApi>
		<AspectGeneratorDebuggerStepThrough Condition="'$(AspectGeneratorDebuggerStepThrough)' == ''">false</AspectGeneratorDebuggerStepThrough>
	</PropertyGroup>

	<ItemGroup>
		<CompilerVisibleProperty Include="AspectGeneratorGenerateApi" />
		<CompilerVisibleProperty Include="AspectGeneratorGenerateInterceptors" />
		<CompilerVisibleProperty Include="AspectGeneratorPublicApi" />
		<CompilerVisibleProperty Include="AspectGeneratorDebuggerStepThrough" />
		<CompilerVisibleProperty Include="AspectGeneratorVerbosity" />
		<CompilerVisibleProperty Include="AspectGeneratorInterceptorsNamespace" />
		<CompilerVisibleProperty Include="InterceptorsNamespaces" />
	</ItemGroup>
</Project>
